# Life Bookshelf AI v2 - Environment Configuration Template

# Application Settings
APP_NAME=Life Bookshelf AI v2
APP_VERSION=2.1.0
DEBUG=false
HOST=0.0.0.0
PORT=3000

# AWS Bedrock Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here
AWS_REGION=ap-northeast-2
BEDROCK_MODEL_ID=claude-3-sonnet-20240229
BEDROCK_FALLBACK_MODEL_ID=claude-3-haiku-20240307

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Session Configuration
SESSION_TIMEOUT_HOURS=2
MAX_MESSAGE_LENGTH=2000

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/life-bookshelf-ai.log

# CORS Configuration (comma-separated)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Pipeline Configuration
MAX_CONTEXT_MESSAGES=10
LLM_MAX_TOKENS=1000
LLM_TEMPERATURE=0.7
LLM_TIMEOUT_SECONDS=30

# Feature Flags
INCLUDE_ANALYSIS=true
INCLUDE_SUGGESTIONS=true
