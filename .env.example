# Life Bookshelf AI v2 - Environment Configuration Template
# Copy this file to .env.development and fill in your actual values

# =============================================================================
# APPLICATION SETTINGS (선택사항 - 기본값 사용 가능)
# =============================================================================

# 애플리케이션 기본 정보
APP_NAME=Life Bookshelf AI v2
APP_VERSION=2.1.0

# 개발 모드 설정 (true: 상세 로그, 자동 재시작)
DEBUG=false

# 서버 설정
HOST=0.0.0.0
PORT=3000

# =============================================================================
# AWS BEDROCK CONFIGURATION (필수 - LLM 서비스용)
# =============================================================================

# AWS 계정 인증 정보 (필수)
# AWS IAM에서 Bedrock 권한이 있는 사용자의 키 필요
AWS_ACCESS_KEY_ID=your_aws_access_key_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_key_here

# AWS 리전 (Claude 3 지원 리전)
AWS_REGION=ap-northeast-2

# Bedrock 모델 ID (Claude 3 모델)
BEDROCK_MODEL_ID=claude-3-sonnet-20240229
BEDROCK_FALLBACK_MODEL_ID=claude-3-haiku-20240307

# =============================================================================
# REDIS CONFIGURATION (선택사항 - 세션 관리용)
# =============================================================================

# Redis 연결 URL (로컬 개발시 기본값 사용 가능)
REDIS_URL=redis://localhost:6379

# Redis 비밀번호 (클라우드 Redis 사용시 필요)
REDIS_PASSWORD=

# =============================================================================
# SESSION & SECURITY SETTINGS (선택사항 - 기본값 권장)
# =============================================================================

# 세션 만료 시간 (시간 단위)
SESSION_TIMEOUT_HOURS=2

# 사용자 메시지 최대 길이 (문자 수)
MAX_MESSAGE_LENGTH=2000

# =============================================================================
# LOGGING CONFIGURATION (선택사항)
# =============================================================================

# 로그 레벨 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 로그 파일 경로
LOG_FILE=logs/life-bookshelf-ai.log

# =============================================================================
# CORS CONFIGURATION (선택사항 - 프론트엔드 연동시 필요)
# =============================================================================

# 허용할 Origin 목록 (쉼표로 구분)
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# =============================================================================
# PIPELINE CONFIGURATION (선택사항 - 성능 튜닝용)
# =============================================================================

# 대화 컨텍스트에 포함할 최대 메시지 수
MAX_CONTEXT_MESSAGES=10

# LLM 최대 토큰 수
LLM_MAX_TOKENS=1000

# LLM 창의성 설정 (0.0-1.0, 높을수록 창의적)
LLM_TEMPERATURE=0.7

# LLM 응답 대기 시간 (초)
LLM_TIMEOUT_SECONDS=30

# =============================================================================
# FEATURE FLAGS (선택사항 - 기능 활성화/비활성화)
# =============================================================================

# 메시지 분석 기능 포함 여부
INCLUDE_ANALYSIS=true

# 후속 질문 제안 기능 포함 여부
INCLUDE_SUGGESTIONS=true