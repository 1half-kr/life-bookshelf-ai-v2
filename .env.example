# Life Bookshelf AI v2 - 환경 변수 설정

# 서버 설정
HOST=0.0.0.0
PORT=3000
DEBUG=false

# Vector Database
CHROMA_PERSIST_DIRECTORY=./chroma_db

# 로깅
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# 보안
SECRET_KEY=your_secret_key_here
ALLOWED_HOSTS=localhost,127.0.0.1

# 기능 플래그
ENABLE_VECTOR_DB=true
ENABLE_STREAMING=true
