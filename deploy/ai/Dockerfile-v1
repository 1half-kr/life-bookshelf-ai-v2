FROM python:3.9

# 작업 디렉토리 설정
WORKDIR /app

# Python 의존성 설치
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt

# 애플리케이션 코드 복사
COPY ./serve/ ./serve/
COPY ./shared/ ./shared/

# Vector Database 및 로그 디렉토리 생성
RUN mkdir -p /app/chroma_db /app/logs

# 작업 디렉토리를 serve로 변경
WORKDIR /app/serve

# 환경 변수 설정
ENV PYTHONPATH=/app
ENV CHROMA_PERSIST_DIRECTORY=/app/chroma_db

# 포트 노출
EXPOSE 3000

# FastAPI 애플리케이션 실행 (main_realtime.py 사용)
CMD ["uvicorn", "main_realtime:app", "--host", "0.0.0.0", "--port", "3000"]